{
    "[markdown]": {
        "editor.defaultFormatter": "yzhang.markdown-all-in-one"
    },
    "grammarly.userWords": [
        "Localdb",
        "cli",
        "dbaconnection",
        "dbatools",
        "docset",
        "gists",
        "ldf",
        "localdb",
        "mdf",
        "pwsh",
        "CLI"
    ], // no protected branches on this blog repo, as I edit and work with master directly for CI
    "branchwarnings.protectedBranches": [
        ""
    ],
    "conventionalCommits.scopes": [
        "blog",
        "build",
        "netlifycms",
        "microblog"
    ],
    "[yaml]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.quickSuggestions": {
            "other": true,
            "comments": false,
            "strings": true
        },
        "editor.autoIndent": "advanced",
    },
    "go.inferGopath": false,
    "staticWebApps.appSubpath": "/",
    "staticWebApps.apiSubpath": "/",
    "staticWebApps.appArtifactSubpath": "build",
    // "go.toolsGopath": "~/.go/pkg/tool/linux_amd64",
    "go.goroot": "~/.go",
    "go.docsTool": "gogetdoc",
    "go.useCodeSnippetsOnFunctionSuggest": true,
    "go.useCodeSnippetsOnFunctionSuggestWithoutType": true,
    "go.useLanguageServer": true,
    "goOutliner.extendExplorerTab": true
}
